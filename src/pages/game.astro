---
import PageLayout from '../components/PageLayout.astro';
import ImageButton from '../components/ImageButton.astro';
---

<PageLayout 
	title="Game - Liam Power" 
	backgroundImage="/placeholder.png"
	altText="Game background"
>
	<!-- Game specific buttons - more interactive layout -->
	<ImageButton 
		id="game-button1" 
		dataImage="/room_1920x1080_Improved_labels.png"
		top="15%"
		left="10%"
		buttonWidth="15%"
		buttonHeight="10%"
		buttonOpacity="100%"
	/>
	
	<ImageButton 
		id="game-button2" 
		dataImage="/room_1920x1080.png"
		top="15%"
		left="30%"
		buttonWidth="15%"
		buttonHeight="10%"
		buttonOpacity="100%"
	/>
	
	<ImageButton 
		id="game-button3" 
		dataImage="/room_1920x1080 copy.png"
		top="15%"
		left="50%"
		buttonWidth="15%"
		buttonHeight="10%"
		buttonOpacity="100%"
	/>
	
	<ImageButton 
		id="game-button4" 
		dataImage="/placeholder.png"
		top="15%"
		left="70%"
		buttonWidth="15%"
		buttonHeight="10%"
		buttonOpacity="100%"
	/>
	
