		id="game-button7" 
		dataImage="/room_1920x1080 copy.png"
		top="35%"
		left="60%"
		buttonWidth="12%"
		buttonHeight="15%"
		buttonOpacity="100%"
	/>
	
	<ImageButton 
		id="game-button8" 
		dataImage="/placeholder.png"
		top="35%"
		left="80%"
		buttonWidth="12%"
		buttonHeight="15%"
		buttonOpacity="100%"
	/>
</PageLayout> 