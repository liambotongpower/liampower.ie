---
import PageLayout from '../components/PageLayout.astro';
import NavButton from '../components/NavButton.astro';
import CycleButton from '../components/CycleButton.astro';
---

<PageLayout 
	title="Liam Power" 
	backgroundImage="/room_1920x1080_Improved_labels.png"
	altText="Background image"
>
	<!-- Navigation buttons for different pages -->
	<NavButton 
		id="homeButton" 
		dataPage="/"
		top="7%"
		left="3%"
		buttonWidth="24.5%"
		buttonHeight="7%"
		buttonOpacity="0%"
	/>
	
	<NavButton 
		id="aboutMeButton" 
		dataPage="/aboutme"
		top="8%"
		left="48%"
		buttonWidth="16.5%"
		buttonHeight="6%"
		buttonOpacity="0%"
	/>
	
	<NavButton 
		id="projectsButton" 
		dataPage="/projects"
		top="8%"
		left="67%"
		buttonWidth="14%"
		buttonHeight="7%"
		buttonOpacity="0%"
	/>
	
	<NavButton 
		id="contactButton" 
		dataPage="/contact"
		top="8%"
		left="83.5%"
		buttonWidth="13.5%"
		buttonHeight="6%"
		buttonOpacity="0%"
	/>
	
	<NavButton 
		id="gameButton" 
		dataPage="/game"
		top="68%"
		left="83.5%"
		buttonWidth="13.5%"
		buttonHeight="6%"
		buttonOpacity="100%"
	/>
	
	<!-- Cycle button for cycling through background images -->
	<CycleButton 
		id="cycleButton" 
		images={[
			"/room_1920x1080_Improved_labels.png",
			"/room_1920x1080.png",
			"/room_1920x1080 copy.png",
			"/placeholder.png"
		]}
		top="68%"
		left="3%"
		buttonWidth="20%"
		buttonHeight="6%"
		buttonOpacity="100%"
	/>
</PageLayout>
